generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

// Model name is lowercase `products` on purpose: your service uses `this.prisma.products`,
// and the accessor is derived directly from the model name.
model products {
  id              String   @id @default(cuid())

  // --- read-contract fields ---
  productCode     String
  normalizedCode  String
  uom             String

  costPerUom      Decimal? @db.Decimal(12, 4) // nullable in source
  weightLbs       Decimal? @db.Decimal(10, 3)
  margin          Decimal  @default(0) @db.Decimal(5, 2) // 0–99.99 enforced in the DTO
  caseQty         Int      @default(1)

  // --- descriptive / catalog-tool fields ---
  description     String?
  title           String?
  dimensions      String?
  imageUrl        String?
  manufacturerUrl String?
  submittalUrl    String?
  notes           String?

  active          Boolean  @default(true)
  published       Boolean  @default(false)

  // --- scalar FKs + relations ---
  vendorId        String?
  vendor          vendors? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  typeId          String?
  type            product_types? @relation(fields: [typeId], references: [id], onDelete: SetNull)

  // --- soft-delete + audit ---
  archivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([normalizedCode])
  @@index([vendorId])
  @@index([typeId])
  @@index([updatedAt]) // findAll orders by updatedAt desc
}

model vendors {
  id        String     @id @default(cuid())
  name      String
  products  products[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model product_types {
  id        String     @id @default(cuid())
  name      String
  products  products[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}