generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ingest_batches {
  id            String        @id
  source        String
  vendorId      String?
  status        String        @default("open")
  columnMapping Json?
  fileRef       String?
  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now())
  vendors       vendors?      @relation(fields: [vendorId], references: [id], onUpdate: NoAction)
  ingest_rows   ingest_rows[]
}

model ingest_rows {
  id               String         @id
  batchId          String
  rawData          Json?
  mappedData       Json?
  status           String         @default("pending")
  matchedProductId String?
  resolution       String?
  diff             Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now())
  ingest_batches   ingest_batches @relation(fields: [batchId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products         products?      @relation(fields: [matchedProductId], references: [id], onUpdate: NoAction)

  @@index([batchId], map: "idx_ingest_rows_batch_id")
  @@index([status], map: "idx_ingest_rows_status")
}

model product_tags {
  productId String
  tagId     String
  products  products @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tags      tags     @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([productId, tagId])
  @@index([tagId], map: "idx_product_tags_tag_id")
}

model product_types {
  id         String     @id
  name       String     @unique
  archivedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @default(now())
  products   products[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model products {
  id                  String         @id
  normalizedCode      String         @unique(map: "uq_products_normalized_code_active", where: raw("(\"archivedAt\" IS NULL)"))
  productCode         String
  costPerUom          Decimal?       @db.Decimal(14, 4)
  uom                 String
  weightLbs           Decimal?       @db.Decimal(12, 4)
  active              Boolean        @default(true)
  published           Boolean        @default(false)
  description         String?
  category            String?
  categoryDescription String?
  commonNames         String?
  uses                String?
  link                String?
  dateLastUpdated     DateTime?
  title               String?
  margin              Decimal        @default(25) @db.Decimal(5, 2)
  caseQty             Int            @default(1)
  dimensions          String?
  imageUrl            String?
  manufacturerUrl     String?
  submittalUrl        String?
  notes               String?
  vendorId            String?
  typeId              String?
  archivedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @default(now())
  ingest_rows         ingest_rows[]
  product_tags        product_tags[]
  product_types       product_types? @relation(fields: [typeId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  vendors             vendors?       @relation(fields: [vendorId], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([archivedAt], map: "idx_products_archived_at")
  @@index([productCode], map: "idx_products_product_code")
  @@index([typeId], map: "idx_products_type_id")
  @@index([vendorId], map: "idx_products_vendor_id")
}

model tags {
  id           String         @id
  name         String         @unique
  createdAt    DateTime       @default(now())
  product_tags product_tags[]
}

model vendors {
  id             String           @id
  name           String           @unique
  archivedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now())
  ingest_batches ingest_batches[]
  products       products[]
}
